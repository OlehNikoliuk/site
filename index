<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Document</title>
</head>
<body>
    <nav class="navbar">
        <div id="logo-container">
            <span id="logo" class="logo">Author</span>
            <div id="author-info" class="hidden">
                <img src="IMG_6739.jpg" style="width: 20%; height: 20%; margin-bottom: 1rem;">
                <p>Name: Artem Chubei</p>
                <p>Group: 211-B</p>
            </div>
        </div>
        <ul class="nav-links">
            <li><button onclick="showtask(1)">Area Calculator</button></li>
            <li><button onclick="showtask(2)">Money Writer</button></li>
            <li><button onclick="showtask(3)">Text Editor</button></li>
        </ul>
    </nav>

    <main id="tasks-container">
        <section id="task1" class="task-block">
            <h2>Area Calculator</h2>
            <p>Choose a shape and enter its measurements to calculate its area:</p>
            <select id="shape-select">
                <option value="">Select a shape</option>
                <option value="circle">Circle</option>
                <option value="triangle">Triangle(base+height)</option>
                <option value="rectangle">Rectangle</option>
            </select>
            <div id="shape-inputs">
                <input type="number" id="value1" placeholder="Value 1">
                <input type="number" id="value2" placeholder="Value 2">
            </div>

            <button id="calculate-btn">Calculate Area</button>
            <div id="area-result"></div>
        </section>
        
        <section id="task2" class="task-block" style="display:none;">
            <h2>Money Writer</h2>
            <p>Enter amount to get correct spelling:</p>
            <input type="number" id="money-input" placeholder="Enter amount">
            <button id="convert-btn">Check Spelling</button>
            <div id="money-result"></div>
        </section>
        <section id="task3" class="task-block" style="display:none;">
            <h2>Text Editor</h2>
            <p>Enter text, word for search and replace:</p>
            <textarea id="text-input" placeholder="Enter text here" class="text"></textarea>
            <input type="text" id="search-word" placeholder="Word to search">
            <input type="text" id="replace-word" placeholder="Word to replace with">
            <button id="replace-btn">Replace</button>
            <div id="text-result" class="text-result"></div>
        </section>
    </main>
</body>
<script src="func.js" defer></script>
</html>
